{
  "name": "anime-archive",
  "version": "1.0.0",
  "description": "**アニメ中間制作物（セル画・原画・背景画等）の記録を目的とした標準メタデータスキーマ**",
  "main": "index.js",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "validate": "node validate.js",
    "test": "node validate.js examples/minimal.json examples/full.json && ! node validate.js tests/invalid/*.json"
  },
  "bin": {
    "anime-archive-validate": "./validate.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hiiro-megumi/anime-archive.git"
  },
  "keywords": [],
