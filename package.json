  "bugs": {
    "url": "https://github.com/hiiro-megumi/anime-archive/issues"
  },
  "homepage": "https://github.com/hiiro-megumi/anime-archive#readme",
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  }
}
